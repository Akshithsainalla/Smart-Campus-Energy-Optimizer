# ─────────────────────────────────────────────────────────────────────────────
# SCEO Backend — Environment Variables
# Copy this file to .env and fill in values for your environment.
# When running via Docker locally:  docker run --env-file .env ...
# When deploying to Render:         set these in the Render dashboard / render.yaml
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Spring Boot app listens on.
# Render injects PORT automatically; leave blank to use the default 8080 locally.
PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:5173
# Production: your Vercel / Render frontend URL
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Notes:
#  • The H2 in-memory database requires no extra credentials — it starts
#    automatically on app launch and resets on every restart.
#  • Do NOT commit a real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────
