# ─────────────────────────────────────────────────────────────────────────────
# SCEO Backend — Environment Variables
# Copy this file to .env and fill in your values.
# When running via Docker locally:  docker run --env-file .env ...
# When deploying to Render:         set these in the Render dashboard / render.yaml
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Spring Boot app listens on.
# Render injects PORT automatically; 8080 is the local dev default.
PORT=8080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev  → http://localhost:5173
# Production → your Vercel / Render frontend URL
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ── Aiven MySQL Database ───────────────────────────────────────────────────────
DB_HOST=mysql-3a0f65a1-akshithsai2425-169f.h.aivencloud.com
DB_PORT=28500
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password_here

# ─────────────────────────────────────────────────────────────────────────────
# Notes:
#  • SSL is required by Aiven — already baked into the JDBC URL in
#    application.properties (sslMode=REQUIRED).
#  • Do NOT commit a real .env file (with DB_PASSWORD filled in) to git.
# ─────────────────────────────────────────────────────────────────────────────
